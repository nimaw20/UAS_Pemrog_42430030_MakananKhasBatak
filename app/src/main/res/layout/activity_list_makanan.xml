<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream_bg"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daftar Makanan Khas Batak"
        android:textColor="@color/maroon_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cari makanan..."
        android:padding="12dp"
        android:backgroundTint="@color/maroon_primary"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnCari"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cari"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:backgroundTint="@color/maroon_primary"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnSortAZ"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="A-Z"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:backgroundTint="@color/maroon_light"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnSortZA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Z-A"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:backgroundTint="@color/maroon_dark"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMakanan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>